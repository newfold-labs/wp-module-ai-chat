		"doctrine": "2.1.0"
	},
	"devDependencies": {
		"@wordpress/eslint-plugin": "^24.3.0",
		"@wordpress/prettier-config": "^4.41.0",
		"@wordpress/scripts": "^31.5.0",
		"eslint": "^8.57.1",
		"eslint-plugin-prettier": "^5.5.4",
		"prettier": "^3.6.2"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.0.0",

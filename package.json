{
	"name": "@newfold/wp-module-ai-chat",
	"version": "1.0.3",
	"description": "Reusable AI Chat core for WordPress modules",
	"license": "GPL-2.0-or-later",
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/newfold-labs/wp-module-ai-chat.git"
	},
	"main": "build/index.js",
	"style": "build/index.css",
